      </tran_glyph>
     </tran>
     <tran trig="SP_MNGR_OPEN_SERIAL_PORT">
      <choice target="../../13">
       <guard>SpMngr_comNameIsInvalid(me-&gt;com)</guard>
       <action>BSP_Post2LspThread(
    SP_TRD_OPEN_PORT_SIG,
    me-&gt;com,
    me-&gt;baudrate,
    me-&gt;dataBits,
    me-&gt;stopBits,
    me-&gt;parity,
    me-&gt;flowControl);</action>
       <choice_glyph conn="30,40,4,1,2,10,18,-2">
        <action box="1,2,11,2"/>
       </choice_glyph>
      </choice>
      <choice>
       <guard>else</guard>
       <action>GuiMngrEvt *evt = Q_NEW(GuiMngrEvt, GUI_OPEN_INVALID_COM_SIG);
QACTIVE_POST(AO_GuiMngr, (QEvt*)evt, (void *)0);</action>
       <choice_glyph conn="30,40,5,-1,10">
        <action box="1,0,10,2"/>
       </choice_glyph>
      </choice>
      <tran_glyph conn="4,40,3,-1,26">
       <action box="0,-2,26,2"/>
      </tran_glyph>
     </tran>
     <tran trig="SP_MNGR_RECV_PACKET">
      <action brief="JustInCase">/* In case of memory leaking. */
free(((SpMngrEvt *)e)-&gt;pld.packBuf);</action>
      <tran_glyph conn="4,46,3,-1,22">
       <action box="0,-2,21,2"/>
      </tran_glyph>
     </tran>
     <tran trig="SP_MNGR_UPDATE_SELECTED_JSON_FILE">
      <action>if (me-&gt;currJsonFile) free(me-&gt;currJsonFile);
me-&gt;currJsonFile = ((SpMngrEvt *)e)-&gt;pld.txt;</action>
      <tran_glyph conn="4,52,3,-1,34">
       <action box="0,-2,33,2"/>
      </tran_glyph>
     </tran>
     <tran trig="SP_MNGR_LOAD_SELECTED_JSON_FILE">
      <action>/* Load the target json file to local */
SNMTT_loadJSONConfig(me-&gt;currJsonFile);

/* Update loaded json file to Display... */
GuiMngrEvt *evt = Q_NEW(GuiMngrEvt, GUI_MNGR_UPDATE_LOADED_JSON_FILE_SIG);
evt-&gt;txt = strdup(me-&gt;currJsonFile);
QACTIVE_POST(AO_GuiMngr, (QEvt*)evt, (void *)0);</action>
      <tran_glyph conn="4,54,3,-1,34">
       <action box="0,-2,33,2"/>
      </tran_glyph>
     </tran>
     <tran trig="SP_MNGR_RECV_MSG">
      <action>/* Unpackage [Seq.] [RecID] [pldLen] [payload...]... */
uint8_t *currMsg = ((SpMngrEvt *)e)-&gt;pld.msgFrm;
SNMTT_PayloadParser *recIdParser = SNMTT_RX_getRecID(currMsg[1]);
if (recIdParser != NULL) {  /* Valid RecID. */
    uint8_t pldSize = currMsg[2];
    uint8_t pldSizeIter = pldSize;
    uint8_t *pldStart = currMsg + 3;
    uint16_t msgSize = strlen(recIdParser-&gt;format) + 1; /* '\0'. */
    msgSize += 6;  /* &quot;[%03d]&quot; &quot;... ...&quot; */
    char *nFmt = malloc(msgSize);
    Q_ENSURE(nFmt != NULL);
    /* Format update. */
    snprintf(nFmt, msgSize,
            &quot;[%%03d]%s&quot;, recIdParser-&gt;format);
    msgSize = strlen(nFmt);
    char *fmtArgv[SNMTT_ARGS_NUM_MAX] = {
        NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL,
        NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL
    };
    for (
        int i = 0;
        (i &lt; SNMTT_ARGS_NUM_MAX) &amp;&amp; (pldSizeIter &gt; 0);
        ++i
    ) {
        /* Valid parser arg... */
        if (recIdParser-&gt;args[i]) {
            if (
                recIdParser-&gt;args[i]-&gt;radix == SNMTT_RADIX_STRING
            ) {
                /* String of module... */
                /* Collecting all the rest payload... */
                char *moduleStr = malloc(pldSizeIter + 1);
                Q_ENSURE(moduleStr != (char *)0);
                memcpy(
                    moduleStr, pldStart + (pldSize - pldSizeIter),
                    pldSizeIter);
                moduleStr[pldSizeIter] = '\0';
                fmtArgv[i] = moduleStr; /* To dispMsg. */
                msgSize += strlen(fmtArgv[i]);
                pldSizeIter = 0; /* Break loop. */
            } else if (
                recIdParser-&gt;args[i]-&gt;argLen &lt;= pldSizeIter
            ) {
                /* Normal parsing... */
                fmtArgv[i] =
                    SNMTT_itoa(
                        pldStart + (pldSize - pldSizeIter),
                        recIdParser-&gt;args[i]-&gt;argLen,
                        recIdParser-&gt;args[i]-&gt;radix);
                msgSize += strlen(fmtArgv[i]);
                pldSizeIter -= recIdParser-&gt;args[i]-&gt;argLen;
            }
        }
    }
    char *dispMsg = malloc(msgSize);
    Q_ENSURE(dispMsg != NULL);
    snprintf(dispMsg, msgSize, nFmt, currMsg[0],
            fmtArgv[0],  fmtArgv[1],  fmtArgv[2],  fmtArgv[3],
            fmtArgv[4],  fmtArgv[5],  fmtArgv[6],  fmtArgv[7],
            fmtArgv[8],  fmtArgv[9],  fmtArgv[10], fmtArgv[11],
            fmtArgv[12], fmtArgv[13], fmtArgv[14], fmtArgv[15]);
    free(nFmt);
    /* Free memory generated from *SNMTT_itoa. */
    for (int i = 0; i &lt; SNMTT_ARGS_NUM_MAX; ++i) {
        if (fmtArgv[i]) free(fmtArgv[i]);
    }
    /* Send disMsg to Display. */
    GuiMngrEvt *evt = Q_NEW(GuiMngrEvt, GUI_MNGR_RECV_MSG_SIG);
    evt-&gt;txt = dispMsg;
    QACTIVE_POST(AO_GuiMngr, (QEvt*)evt, (void *)0);
} else {  /* Invalid RecID. */
    /* Send [Seq.][RecID][pldLen] frame to Display. */
    uint8_t dispMsgLen = 22 + 1;
    char *dispMsg = malloc(dispMsgLen);
    Q_ENSURE(dispMsg != (char *)0);
    snprintf(
        dispMsg, dispMsgLen, &quot;[%03d][%03d][%03d][????]\n&quot;,
        currMsg[0], currMsg[1], currMsg[2]);
    GuiMngrEvt *evt = Q_NEW(GuiMngrEvt, GUI_MNGR_RECV_MSG_SIG);
    evt-&gt;txt = dispMsg;
    QACTIVE_POST(AO_GuiMngr, (QEvt*)evt, (void *)0);
}
free(((SpMngrEvt *)e)-&gt;pld.msgFrm); /*! GC. */</action>
      <tran_glyph conn="4,48,3,-1,22">
       <action box="0,-2,21,2"/>
      </tran_glyph>
