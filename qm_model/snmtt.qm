   <text>/*==========================================================================*/
#ifndef SP_MNGR_H_
#define SP_MNGR_H_

/*==========================================================================*/
extern QActive * const AO_SpMngr; /* Global opaque pointer. */

/*==========================================================================*/
void SpMngr_ctor(void);

/*==========================================================================*/
/* ===lspThread events. */
#include &quot;spthread_evt.h&quot;

/*==========================================================================*/
/* ===Json file parser. */
#include &quot;snmtt_json_parser.h&quot;

/*==========================================================================*/
/* ===HLDC bytes parser. */
#include &quot;snmtt_hldc_parser.h&quot;

#endif  /* SP_MNGR_H_ */</text>
  </file>
  <file name="sp_mngr.c" codec="UTF-8">
   <text>/*==========================================================================*/
#include &quot;qpc.h&quot;
#include &quot;bsp.h&quot;
#include &quot;application.h&quot;

/*==========================================================================*/
Q_DEFINE_THIS_MODULE(&quot;sp_mngr&quot;)

/*==========================================================================*/
/* ===SpMngr Active Object (AO) class. */
$declare ${AOs::SpMngr}

/*==========================================================================*/
/* ===AO instance. */
SpMngr SpMngr_inst;
QActive * const AO_SpMngr = &amp;SpMngr_inst.super;

/*==========================================================================*/
void SpMngr_ctor(void) {
    /* 'me' points to the Blinky instance. */
    SpMngr * const me = &amp;SpMngr_inst;

    /* call the superclass' constructor. */
    QActive_ctor(&amp;me-&gt;super, Q_STATE_CAST(&amp;SpMngr_initial));

    /* call the members' constructors. */
    QTimeEvt_ctorX(&amp;me-&gt;timeEvt, &amp;me-&gt;super, TIMEOUT_SIG, 0U);

    /* default constructor... */
    me-&gt;com[0] = 'N'; me-&gt;com[1] = 'U'; me-&gt;com[2] = 'L'; me-&gt;com[3] = 'L';
    me-&gt;com[4] = '\0';

    me-&gt;baudrate    = 115200;
    me-&gt;dataBits    = 8;
    me-&gt;stopBits    = SP_STOPBITS_1_OP;
    me-&gt;parity      = SP_PARITY_NONE_OP;
    me-&gt;flowControl = SP_FLOW_NONE_OP;

    /* Default !NULL, for GC operation. */
    me-&gt;currJsonFile = strdup(&quot;Empty&quot;);

    HLDCPaser_ctor();
}

/*==========================================================================*/
/* ...String -&gt; Int */
int str_to_baud(const char *str) {
    if (!str) return 115200; /* Default. */
    return atoi(str);
}
/*..........................................................................*/
/* ...String -&gt; Int. */
int str_to_databits(const char *str) {
    if (!str) return 8;
    return atoi(str); // &quot;8&quot; -&gt; 8, &quot;5&quot; -&gt; 5
}
/*..........................................................................*/
/* ...String -&gt; Enum. */
SerialStopBits_t str_to_stopbits(const char *str) {
    if (!str) return SP_STOPBITS_1_OP;
    if (strcmp(str, &quot;1.5&quot;) == 0) {
        return SP_STOPBITS_1_5_OP;
    } else if (strcmp(str, &quot;2&quot;) == 0) {
        return SP_STOPBITS_2_OP;
    } else {
        return SP_STOPBITS_1_OP;
    }
}
/*..........................................................................*/
/* ...String -&gt; Enum. */
SerialParity_t str_to_parity(const char *str) {
    if (!str) return SP_PARITY_NONE_OP;
    if (strcmp(str, &quot;Odd&quot;) == 0)        return SP_PARITY_ODD_OP;
    else if (strcmp(str, &quot;Even&quot;) == 0)  return SP_PARITY_EVEN_OP;
    else if (strcmp(str, &quot;Mark&quot;) == 0)  return SP_PARITY_MARK_OP;
    else if (strcmp(str, &quot;Space&quot;) == 0) return SP_PARITY_SPACE_OP;
    return SP_PARITY_NONE_OP;
}
/*..........................................................................*/
/* ...String -&gt; Enum. */
SerialFlow_t str_to_flowcontrol(const char *str) {
    if (!str) return SP_FLOW_NONE_OP;
    if (strcmp(str, &quot;Xon/Xoff&quot;) == 0)   return SP_FLOW_XON_XOFF_OP;
    else if (strcmp(str, &quot;RTS/CTS&quot;) == 0) return SP_FLOW_RTS_CTS_OP;
    else if (strcmp(str, &quot;DTR/DSR&quot;) == 0) return SP_FLOW_DTR_DSR_OP;
    return SP_FLOW_NONE_OP;
}
/*..........................................................................*/
bool SpMngr_comNameIsInvalid(char *comName) {
    if (
        (strcmp(comName, &quot;NULL&quot;) == 0) ||
            (strcmp(comName, &quot;ERROR&quot;) == 0)
    ) {
        return false;
    }
    return true;
}

/*..........................................................................*/
/* ...State machine. */
$define ${AOs::SpMngr}</text>
  </file>
