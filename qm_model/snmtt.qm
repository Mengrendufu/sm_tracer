      </tran>
      <tran trig="SP_MNGR_PORT_ERR_SHUT_DOWN" target="../..">
       <action>GuiMngrEvt *evt = Q_NEW(GuiMngrEvt, GUI_MNGR_PORT_ERR_SHUT_DOWN_SIG);
QACTIVE_POST(AO_GuiMngr, (QEvt *)evt, (void *)0);</action>
       <tran_glyph conn="6,86,3,1,36">
        <action box="0,-2,30,2"/>
       </tran_glyph>
      </tran>
      <tran trig="SP_MNGR_CLOSE_SERIAL_PORT">
       <action>/* Close port. */
BSP_Post2LspThread(
    SP_TRD_CLOSE_PORT_SIG,
    (char *)0, 0, 0, 0, 0, 0);</action>
       <tran_glyph conn="6,82,3,-1,28">
        <action box="0,-2,28,2"/>
       </tran_glyph>
      </tran>
      <tran trig="SP_MNGR_RECV_PACKET">
       <action>/**
 * Parse the received byte package based on current protocal
 * and generate the frame to Display...
 */
for (int i = 0; i &lt; ((SpMngrEvt *)e)-&gt;pldSize.packSize; ++i) {
    HLDCParser_trigger(((SpMngrEvt *)e)-&gt;pld.packBuf[i]);
}
free(((SpMngrEvt *)e)-&gt;pld.packBuf);  /*! GC. */</action>
       <tran_glyph conn="6,90,3,-1,22">
        <action box="0,-2,22,2"/>
       </tran_glyph>
      </tran>
      <state_glyph node="6,74,32,18"/>
